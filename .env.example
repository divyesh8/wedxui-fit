# ─── Environment Variables ─────────────────────────────
# Copy this file to `.env` and fill in real values.

# ─── Database (Neon PostgreSQL) ────────────────────────
# From the Neon dashboard → Connection Details.
# DATABASE_URL uses the POOLED connection (has "-pooler" in the host) for the app.
# DIRECT_URL uses the DIRECT connection (no "-pooler") for prisma migrate.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/wedxui_fit?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/wedxui_fit?sslmode=require"

# ─── Auth (custom bcrypt + OTP + JWT) ──────────────────
# JWT signing secret. Generate one with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"
# How long a login session lasts before the cookie/JWT expires.
SESSION_TTL_DAYS="7"

# ─── Email / OTP delivery (Resend) ─────────────────────
# Create a key at https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# The "from" address. Until you verify a domain in Resend, use the sandbox sender:
EMAIL_FROM="WEDXUI Fit <onboarding@resend.dev>"
# OTP behavior
OTP_TTL_MINUTES="5"
# When true (or when RESEND_API_KEY is unset), OTP codes are logged to the
# server console instead of emailed — lets you test the full flow with no email setup.
OTP_DEV_MODE="false"

# ─── App ───────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ─── AI (future) ───────────────────────────────────────
# ANTHROPIC_API_KEY=""

# ─── Storage (future — progress photos) ────────────────
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# S3_BUCKET=""
