# ─── Environment Variables ─────────────────────────────
# Copy this file to `.env` and fill in real values.

# ─── Database (Neon PostgreSQL) ────────────────────────
# From the Neon dashboard → Connection Details.
# DATABASE_URL uses the POOLED connection (host contains "-pooler") for the app.
# DIRECT_URL uses the DIRECT connection (no "-pooler") for prisma migrate.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/wedxui_fit?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/wedxui_fit?sslmode=require"

# ─── Auth (custom bcrypt + JWT) ────────────────────────
# Signs login sessions AND derives the AES-256-GCM key that encrypts TOTP
# secrets at rest — so rotating it invalidates sessions and existing 2FA secrets.
# Generate one with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"
# How long a login session lasts before the cookie/JWT expires.
SESSION_TTL_DAYS="7"

# ─── Cron (account deletion) ───────────────────────────
# Bearer token that authenticates the daily account-purge job at
# /api/cron/purge-accounts. Vercel Cron sends this automatically in production;
# set any long random string here for local testing. If unset, the route fails
# closed (503) and purges nothing.
CRON_SECRET="change-me-to-a-long-random-string"

# ─── App ───────────────────────────────────────────────
APP_URL="http://localhost:3000"
